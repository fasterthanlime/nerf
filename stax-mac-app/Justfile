project := "stax.xcodeproj"
scheme := "stax"
config := "Debug"
# Pin DerivedData to a project-local path. Lets `only-run` resolve the
# .app location with a static string instead of asking xcodebuild
# (`-showBuildSettings` re-loads the project + SwiftPM graph and is
# multi-second).
derived := "./DerivedData"
app := derived + "/Build/Products/" + config + "/stax.app"

xcodebuild_flags := "-project " + project + " -scheme " + scheme + " -configuration " + config + " -derivedDataPath " + derived + " -destination 'platform=macOS'"

list:
    just --list

# Regenerate stax.xcodeproj from project.yml
gen:
    xcodegen generate

# Resolve package dependencies (do this once after gen)
resolve: gen
    xcodebuild {{ xcodebuild_flags }} \
        -resolvePackageDependencies

# Build the app (no project regeneration, no package resolution)
build:
    set -o pipefail; \
    xcodebuild {{ xcodebuild_flags }} \
        -disableAutomaticPackageResolution \
        -skipPackageUpdates \
        COMPILER_INDEX_STORE_ENABLE=NO \
        ONLY_ACTIVE_ARCH=YES \
        build 2>&1 | xcbeautify

# Build, then launch from DerivedData (kills any prior instance first)
run: build
    pkill -f /stax.app/Contents/MacOS/stax || true
    @sleep 0.2
    just only-run

only-run:
    open {{ app }}

# Build, copy to /Applications, launch from there
install: build
    pkill -f /stax.app/Contents/MacOS/stax || true
    @sleep 0.2
    rm -rf /Applications/stax.app
    cp -R {{ app }} /Applications/stax.app
    @echo "installed to /Applications/stax.app"
    open /Applications/stax.app

# Open the project in Xcode
xcode: gen
    open {{ project }}

clean:
    xcodebuild -project {{ project }} -scheme {{ scheme }} -configuration {{ config }} -derivedDataPath {{ derived }} clean
    rm -rf .build build {{ derived }}
